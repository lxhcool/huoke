# Huoke API 生产环境配置
APP_NAME=Huoke API
APP_ENV=production
APP_PORT=8000

# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS=https://huoke.lxhcoool.cn,http://huoke.lxhcoool.cn

# 数据库（Docker 内部通过服务名访问）
DATABASE_URL=postgresql://huoke:huoke123@postgres:5432/huoke
REDIS_URL=redis://redis:6379/0

# Joinf 数据源
JOINF_USERNAME=
JOINF_PASSWORD=
JOINF_LOGIN_USER_ID=

# LinkedIn 数据源
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# AI 提取服务
AI_API_KEY=
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_MODEL=Qwen/Qwen3-8B
